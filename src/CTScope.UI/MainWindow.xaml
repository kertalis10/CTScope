<Window x:Class="CTScope.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CTScope"
        Height="900"
        Width="1400"
        WindowState="Maximized"
        Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="#2B2B2B">
            <DockPanel LastChildFill="True">
                <Button Width="170"
                        Padding="10,6"
                        Margin="0,0,12,0"
                        DockPanel.Dock="Left"
                        Content="Open CT Study Folder"
                        Click="OpenCtStudyFolder_Click" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="#CBCBCB"
                           FontSize="12"
                           Text="{Binding SelectedFolderPath}"
                           ToolTip="{Binding SelectedFolderPath}"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="12"
                    Background="#111111"
                    BorderBrush="#404040"
                    BorderThickness="1"
                    CornerRadius="2">
                <Grid>
                    <Rectangle Margin="48"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Width="700"
                               Height="700"
                               Stretch="Fill">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2F2F2F" Offset="0" />
                                <GradientStop Color="#8D8D8D" Offset="0.5" />
                                <GradientStop Color="#242424" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#8A000000"
                            Padding="18,10"
                            CornerRadius="4">
                        <StackPanel>
                            <TextBlock HorizontalAlignment="Center"
                                       Foreground="#F5F5F5"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Text="{Binding ViewerOverlayText}" />
                            <TextBlock HorizontalAlignment="Center"
                                       Margin="0,6,0,0"
                                       Foreground="#D9D9D9"
                                       FontSize="14"
                                       Text="{Binding SliceSummaryText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,12,12,12"
                    Padding="12,18"
                    Width="90"
                    Background="#232323"
                    BorderBrush="#404040"
                    BorderThickness="1"
                    CornerRadius="2">
                <StackPanel VerticalAlignment="Stretch">
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="#E8E8E8"
                               Margin="0,0,0,14"
                               Text="{Binding CurrentSliceText}" />
                    <Slider x:Name="SliceSlider"
                            Minimum="{Binding SliceMin}"
                            Maximum="{Binding SliceMax}"
                            Value="{Binding CurrentSlice}"
                            TickPlacement="Both"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"
                            SmallChange="1"
                            LargeChange="5"
                            IsEnabled="{Binding IsSliceNavigationEnabled}"
                            Orientation="Vertical"
                            Height="520"
                            VerticalAlignment="Center"
                            ValueChanged="SliceSlider_OnValueChanged" />
                    <TextBlock HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               Foreground="#CBCBCB"
                               Text="{Binding SliceSummaryText}" />
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2"
                   Background="#2B2B2B"
                   Foreground="#EAEAEA">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
